  "query": "\n            SELECT\n                message_id,\n                0 AS \"tx_id!: i64\",\n                producer_name,\n                content_json as \"content_json: _\",\n                occurred_on as \"occurred_on: _\",\n                version as \"version!\"\n            FROM outbox_messages\n            WHERE producer_name = $1 AND message_id > $2\n            ORDER BY message_id\n            LIMIT $3\n            ",
