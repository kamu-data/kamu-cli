  "query": "\n            SELECT\n                entry_id as \"entry_id: uuid::Uuid\",\n                account_id as \"account_id: odf::AccountID\",\n                secret_key as key,\n                value as \"value: Vec<u8>\",\n                secret_nonce as \"secret_nonce: Vec<u8>\",\n                created_at,\n                updated_at\n            FROM config_secret_set_entries\n            WHERE resource_id = $1\n              AND resource_generation = $2\n            ORDER BY secret_key\n            ",
