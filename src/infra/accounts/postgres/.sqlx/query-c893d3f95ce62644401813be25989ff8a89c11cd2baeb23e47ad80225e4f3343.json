{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT id           AS \"id: _\",\n                       account_name,\n                       email,\n                       display_name,\n                       account_type AS \"account_type: AccountType\",\n                       avatar_url,\n                       registered_at,\n                       provider,\n                       provider_identity_key\n                FROM accounts\n                WHERE (account_name ILIKE '%'||$1||'%' ESCAPE '\\'\n                    OR display_name ILIKE '%'||$1||'%' ESCAPE '\\')\n                  AND id != ALL($4)\n                ORDER BY account_name\n                LIMIT $2 OFFSET $3\n                ",
