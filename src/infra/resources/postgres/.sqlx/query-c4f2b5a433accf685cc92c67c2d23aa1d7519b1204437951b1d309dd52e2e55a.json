  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                resource_uid as \"uid: uuid::Uuid\",\n                account_id as \"account_id: odf::AccountID\",\n                resource_kind,\n                api_version,\n                resource_name,\n                description,\n                labels,\n                annotations,\n                spec,\n                status,\n                generation,\n                created_at,\n                updated_at,\n                deleted_at,\n                last_reconciled_at,\n                last_event_id\n            FROM resources\n            WHERE account_id = $1\n              AND resource_uid = ANY($2)\n              AND deleted_at IS NULL\n            ",
