  "query": "\n            SELECT\n                resource_id as \"id: uuid::Uuid\",\n                resource_kind as kind,\n                api_version,\n                resource_name as name\n            FROM resources\n            WHERE account_id = $1\n              AND resource_id = ANY($2)\n              AND deleted_at IS NULL\n            ",
