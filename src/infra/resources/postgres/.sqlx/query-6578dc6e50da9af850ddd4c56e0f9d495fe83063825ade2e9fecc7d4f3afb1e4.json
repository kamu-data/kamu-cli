  "query": "\n            SELECT\n                resource_uid as \"uid: uuid::Uuid\",\n                resource_kind as kind,\n                api_version,\n                resource_name as name\n            FROM resources\n            WHERE account_id = $1\n              AND resource_uid = ANY($2)\n              AND deleted_at IS NULL\n            ",
